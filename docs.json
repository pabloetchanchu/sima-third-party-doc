{
  "$schema": "https://mintlify.com/docs.json",
  "name": "SIMA Docs para Desarrolladores",
  "description": "Documentación de la API de Terceros de SIMA — Agricultura Conectada",
  "theme": "mint",
  "colors": {
    "primary": "#00252E",
    "light": "#DDF972",
    "dark": "#0C505B"
  },
  "logo": {
    "light": "/logo/logo_sima_wordmark.webp",
    "dark": "/logo/logo_sima.webp",
    "href": "https://sima.ag"
  },
  "favicon": "/logo/logo_sima.webp",
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "family": "PP Mori",
    "weight": 400,
    "source": "/fonts/PPMori-Regular.woff2",
    "format": "woff2",
    "heading": {
      "family": "PP Mori",
      "weight": 500,
      "source": "/fonts/PPMori-Medium.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "PP Mori",
      "weight": 400,
      "source": "/fonts/PPMori-Regular.woff2",
      "format": "woff2"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#F3F7F8",
      "dark": "#00252E"
    }
  },
  "topbarLinks": [
    {
      "name": "Postman Collection",
      "url": "https://documenter.getpostman.com/view/12638281/2sA3Qy4Thh"
    }
  ],
  "topbarCtaButton": {
    "name": "Contactar soporte",
    "url": "mailto:soporte@sima.ag"
  },
  "api": {
    "openapi": "openapi.yaml",
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "closed"
    },
    "url": "full",
    "examples": {
      "languages": ["curl", "python", "javascript", "php"],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guías",
        "groups": [
          {
            "group": "Empezar",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Guías de Integración",
            "pages": [
              "guides/work-orders",
              "guides/hierarchy-setup",
              "guides/master-data",
              "guides/scouting",
              "guides/sync-strategy",
              "guides/farmers",
              "guides/warehouses",
              "guides/silobags",
              "guides/progress-reports",
              "guides/iot-weather"
            ]
          }
        ]
      },
      {
        "tab": "Referencia de API",
        "groups": [
          {
            "group": "General",
            "pages": [
              "api-reference/overview",
              "api-reference/versions",
              "api-reference/errors-and-limits",
              "api-reference/glossary",
              "api-reference/sima-erp-glossary",
              "api-reference/entity-schemas"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "openapi.yaml"
          }
        ]
      }
    ]
  },
  "footerSocials": {
    "website": "https://sima.ag"
  },
  "settings": {
    "customScripts": [
      "/assets/sima-assistant-loader.js"
    ]
  }
}
